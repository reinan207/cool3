-- ================================================
-- SPEED HACK STATE (funciona com ou sem abrir o menu)
-- ================================================
local speed = 41
local speedEnabled = false
local speedConnection = nil
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local function applySpeed()
    local character = game.Players.LocalPlayer.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.WalkSpeed = speedEnabled and speed or 16
    end
end

local function updateSpeed()
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    if speedEnabled then
        applySpeed()
        speedConnection = RunService.Heartbeat:Connect(function()
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = speed
            end
        end)
    else
        applySpeed()
    end
end

-- Hotkey T (funciona sem abrir o menu)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.T then
        local character = game.Players.LocalPlayer.Character
        if character and character:FindFirstChild("Humanoid") then
            speedEnabled = not speedEnabled
            updateSpeed()
            -- refreshSpeedUI é chamado depois que os elementos existem
            if SpeedLabel then
                SpeedLabel.Text = "Speed: " .. speed .. (speedEnabled and " (ON)" or " (OFF)")
            end
            if SpeedToggleButton then
                SpeedToggleButton.Text = speedEnabled and "On" or "Off"
                SpeedToggleButton.BackgroundColor3 = speedEnabled and Color3.new(0, 0.7, 0) or Color3.new(0.3, 0.3, 0.3)
            end
            if SpeedButton then
                SpeedButton.BackgroundColor3 = speedEnabled and Color3.new(0, 0.74902, 0) or Color3.new(0.74902, 0, 0)
            end
        end
    end
end)

-- Reconecta ao respawnar
game.Players.LocalPlayer.CharacterAdded:Connect(function()
    if speedConnection then speedConnection:Disconnect(); speedConnection = nil end
    wait(1)
    updateSpeed()
end)

