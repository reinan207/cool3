        if not shownHotkeyMsg["fly"] then
            shownHotkeyMsg["fly"] = true
            showNotif("✈ Fly: F ativa/desativa  |  WASD+Q/E  |  SHIFT=turbo")
        end

    elseif input.KeyCode == Enum.KeyCode.N then
        noclipEnabled = not noclipEnabled
        setNoclip(noclipEnabled)
        if NoclipButton then
            NoclipButton.BackgroundColor3 = noclipEnabled and Color3.new(0, 0.74902, 0) or Color3.new(0.74902, 0, 0)
        end
        if not shownHotkeyMsg["noclip"] then
            shownHotkeyMsg["noclip"] = true
            showNotif("👻 NoClip: N ativa/desativa")
        end
    end
end)

