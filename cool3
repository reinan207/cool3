UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.B then
        -- Se ESP ou Tools estiver aberto, fecha e volta pro main
        if ESPMenuWindow.Visible or ToolsMenuWindow.Visible then
            ESPMenuWindow.Visible = false
            ToolsMenuWindow.Visible = false
            MainMenuWindow.Visible = false
        else
            MainMenuWindow.Visible = not MainMenuWindow.Visible
        end

    elseif input.KeyCode == Enum.KeyCode.T then
        local character = game.Players.LocalPlayer.Character
        if character and character:FindFirstChild("Humanoid") then
            speedEnabled = not speedEnabled
            updateSpeed()
            refreshSpeedUI()
        end

    elseif input.KeyCode == Enum.KeyCode.F then
        flyEnabled = not flyEnabled
        setFly(flyEnabled)
        if FlyButton then
            FlyButton.BackgroundColor3 = flyEnabled and Color3.new(0, 0.74902, 0) or Color3.new(0.74902, 0, 0)
